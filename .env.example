# MatRisk AI Environment Variables Example
# Do not place actual keys in this file. Copy to .env and fill in the values.

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
LOGISCHAIN_API_KEY=your_logischain_api_key_here

# Database Configurations
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=secret

# MLflow configuration
MLFLOW_TRACKING_URI=http://localhost:5000
